# Mining Grid Cron Jobs
# Install with: crontab /opt/mining-grid/cron/mining-cron
# Or append with: crontab -l | cat - /opt/mining-grid/cron/mining-cron | crontab -

# Environment
SHELL=/bin/bash
APP_DIR=/opt/mining-grid
LOG_DIR=/var/log/mining-grid

# Mining pool connectivity check - every 15 minutes
*/15 * * * * bash $APP_DIR/scripts/game-health-check.sh >> $LOG_DIR/cron-health.log 2>&1

# Performance monitoring - every 30 minutes
*/30 * * * * bash $APP_DIR/scripts/performance-check.sh >> $LOG_DIR/cron-performance.log 2>&1

# Crash recovery trigger - every 5 minutes (lightweight check)
*/5 * * * * systemctl is-active --quiet mining-grid.service || bash $APP_DIR/scripts/mining-recovery.sh >> $LOG_DIR/cron-recovery.log 2>&1

# Weekly log rotation - every Sunday at 02:00
0 2 * * 0 find $LOG_DIR -name "*.log" -mtime +7 -exec gzip {} \; && find $LOG_DIR -name "*.log.gz" -mtime +30 -delete
